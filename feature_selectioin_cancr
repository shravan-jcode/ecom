# Import libraries
from sklearn.datasets import load_breast_cancer
from sklearn.feature_selection import VarianceThreshold
import pandas as pd
import numpy as np

# Load dataset
data = load_breast_cancer()
X = pd.DataFrame(data.data, columns=data.feature_names)
y = data.target

# Variance Thresholding: remove features with low variance
selector = VarianceThreshold(threshold=0.2)  # remove features with variance < 0.2
X_var = pd.DataFrame(selector.fit_transform(X), columns=X.columns[selector.get_support()])

print("Number of features after Variance Thresholding:", X_var.shape[1])

# Correlation Analysis: remove highly correlated features
corr_matrix = X_var.corr().abs()
upper = corr_matrix.where(np.triu(np.ones(corr_matrix.shape), k=1).astype(bool))
to_drop = [col for col in upper.columns if any(upper[col] > 0.9)]  # drop features with correlation > 0.9
X_reduced = X_var.drop(columns=to_drop)

print("Number of features after Correlation Analysis:", X_reduced.shape[1])
print("Remaining features:", X_reduced.columns.tolist())
