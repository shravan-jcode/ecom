import pandas as pd

sales = pd.read_csv("sales.csv")
customers = pd.read_csv("customer.csv")

# Merge datasets using department_id
data = pd.merge(sales, customers, on="customer_id", how="left")

# Handle missing values (if any)
data["email"] = data["email"].fillna("Not Available")

# Show datatype before conversion
print("Date datatype BEFORE conversion:", data["date"].dtype)

data["date"] = pd.to_datetime(data["date"])

# Show datatype after conversion
print("Date datatype AFTER conversion:", data["date"].dtype)

# Rename column
data.rename(columns={"total_price": "sales_amount"}, inplace=True)

# Show merged data
print("\nMerged Data")
print(data)

# Aggregate: Average salary per department
summary = data.groupby("name")["sales_amount"].sum()

print("\nTotal Sales Per Customer:")
print(summary)
